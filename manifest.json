{
    "manifest_version": 3,
    "name": "ConteXia",
    "version": "1.0.0",
    "description": "Context-aware AI reading assistant",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "sidePanel",
        "tabs",
        "contextMenus",
        "audioCapture"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "src/background/service_worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content/content_script.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "action": {
        "default_title": "Open ConteXia"
    }
}